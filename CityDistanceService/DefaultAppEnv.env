# Authentication Configuration
AUTH_USERNAME=admin
AUTH_PASSWORD=password

# Database Configuration
DATABASE_CONNECTION_STRING=Server=cds-db;Database=CityDistanceService;Port=3306;Uid=root;Pwd=changeme;

# Data Files Configuration
# Path to JSON city files (e.g., en_cities.json, de_cities.json)
# Each language file should contain cities with metadata and cities array
DATA_FILES_PATH=/app/output

# Elasticsearch Configuration
Elasticsearch__Url=http://elasticsearch:9200
Elasticsearch__Password=testPassword123

# Application Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080
