# Authentication Configuration
AUTH_USERNAME=admin
AUTH_PASSWORD=password

# Database Configuration
DATABASE_CONNECTION_STRING=Server=db;Database=CityDistanceService;Port=3306;Uid=root;Pwd=changeme;

# Stateless Mode Configuration
# When true: Uses existing SQL data, disables Wikidata fetching on startup
# When false: Fetches from Wikidata (not recommended for production)
STATELESS_MODE=true

# Elasticsearch Index Building
# When true: App waits for ES index to be fully built before starting
# When false: App starts immediately (ES built in background)
WAIT_FOR_ES_INDEX=true

# Data Generation Interval (days)
# How often DataGenerationService fetches from Wikidata and regenerates SQL file
# Set to 0 to disable automatic generation
DATA_GENERATION_INTERVAL_DAYS=30

# Elasticsearch Configuration
Elasticsearch__Url=http://elasticsearch:9200
Elasticsearch__Password=testPassword123

# Application Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080